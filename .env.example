# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================

# Telegram Bot Token (BotFather dan olinadi)
BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# GOOGLE SHEETS CONFIGURATION
# ============================================

# Google Sheets ID (URL dan olinadi)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Service Account fayl nomi
SERVICE_ACCOUNT_FILE=service_account.json

# Google Worksheet nomi
GOOGLE_WORKSHEET_NAME=Sheet1

# ============================================
# OPENAI CONFIGURATION
# ============================================

# OpenAI API Key (platform.openai.com dan olinadi)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model
OPENAI_MODEL=gpt-4o-mini

# ============================================
# DEFAULT SETTINGS
# ============================================

# Default rasm URL
DEFAULT_IMAGE_URL=

# ============================================
# XAVFSIZLIK ESLATMALARI
# ============================================
# 1. Bu faylni HECH QACHON git ga yuklamang!
# 2. .env yaratish: cp .env.example .env
# 3. .env da haqiqiy qiymatlarni kiriting
